[
  {
    "layer": "top",
    "position": "top",
    "spacing": 6,
    "height": 44,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": ["custom/theme", "hyprland/workspaces", "custom/network"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["pulseaudio", "cpu", "memory", "custom/battery", "clock", "tray", "custom/power"],

    "custom/theme": {
      "exec": "sh ~/.config/waybar/scripts/bsdrunner-theme-status.sh",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true,
      "on-click": "sh ~/.config/waybar/scripts/bsdrunner-theme-menu.sh"
    },

    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "format": "[{name}]",
      "persistent-workspaces": {
        "*": 4
      }
    },

    "hyprland/window": {
      "format": "ACTIVE {class}: {}",
      "max-length": 64,
      "separate-outputs": true
    },

    "custom/network": {
      "exec": "sh ~/.config/waybar/scripts/bsdrunner-network.sh",
      "return-type": "json",
      "interval": 5,
      "format": "{}",
      "tooltip": true
    },

    "pulseaudio": {
      "format": "AUD {volume}%",
      "format-muted": "AUD MUTE",
      "tooltip-format": "Volume: {volume}%",
      "tooltip-format-muted": "Audio muted",
      "on-click": "pavucontrol"
    },

    "cpu": {
      "interval": 3,
      "format": "CPU {usage}%",
      "tooltip-format": "CPU usage: {usage}%"
    },

    "memory": {
      "interval": 5,
      "format": "MEM {percentage}%",
      "tooltip-format": "Memory in use: {used:0.1f}G / {total:0.1f}G"
    },

    "custom/battery": {
      "exec": "sh ~/.config/waybar/scripts/bsdrunner-battery.sh",
      "return-type": "json",
      "interval": 30,
      "format": "{}",
      "tooltip": true
    },

    "clock": {
      "interval": 1,
      "format": "{:%H:%M  %a %d %b}",
      "format-alt": "{:%A %B %d  %I:%M %p}",
      "tooltip-format": "<tt>{calendar}</tt>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1
      }
    },

    "tray": {
      "icon-size": 16,
      "spacing": 8
    },

    "custom/power": {
      "format": "SYS",
      "tooltip": true,
      "tooltip-format": "Open power menu",
      "on-click": "wlogout -l ~/.config/wlogout/layout -C ~/.config/wlogout/style.css --buttons-per-row 3 --column-spacing 18 --row-spacing 18 --margin 40"
    }
  }
]
